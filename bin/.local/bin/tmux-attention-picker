#!/usr/bin/env bash
# tmux-attention-picker: show all Claude Code and Codex sessions with status info.
# Displayed in a tmux popup via Prefix+A.
# Shows directory, git branch, and status for each pane running Claude Code or Codex.
set -euo pipefail

MAX_SESSIONS=50
FLEX_FLIP_COLUMNS=120
FLEX_FLIP_LINES=40

ATTN_DIR_CLAUDE="${XDG_CACHE_HOME:-$HOME/.cache}/claude/attention"
ATTN_DIR_CODEX="${XDG_CACHE_HOME:-$HOME/.cache}/codex/attention"
TTL=300 # 5 minutes
NOW=$(date +%s)

# Catppuccin Mocha palette — raw ESC bytes so printf '%s' works safely.
RESET=$'\033[0m'
BOLD=$'\033[1m'
RED=$'\033[38;2;243;139;168m'     # #f38ba8
MAROON=$'\033[38;2;235;160;172m'  # #eba0ac
FLAMINGO=$'\033[38;2;242;205;205m' # #f2cdcd
TEAL=$'\033[38;2;148;226;213m'    # #94e2d5
LAVENDER=$'\033[38;2;180;190;254m' # #b4befe
WHITE=$'\033[38;2;205;214;244m'   # #cdd6f4 (Catppuccin text)
TMUX_GREEN=$'\033[38;2;166;227;161m'    # #a6e3a1 (Catppuccin green)
CLAUDE_PEACH=$'\033[38;2;250;179;135m'  # #fab387 (Catppuccin peach)
CODEX_TEAL=$'\033[38;2;148;226;213m'    # #94e2d5 (Catppuccin teal)

# Tool-type icons (nerd fonts).
ICON_CLAUDE="󰛄"   # nf-md-asterisk (f06c4)
ICON_CODEX=""   # nf-oct-terminal (f489)

# Read all key=value fields from a marker file into _marker_fields.
# Single file read with bash builtins — no grep/cut forks.
declare -A _marker_fields
_read_marker() {
  _marker_fields=()
  local key val
  while IFS='=' read -r key val; do
    [[ -n "$key" ]] && _marker_fields[$key]="$val"
  done < "$1"
}

_preview_window_layout() {
  local size width height _
  size=$(tmux display-message -p '#{window_width} #{window_height}' 2>/dev/null || true)
  read -r width height _ <<< "$size"

  # Match Telescope's flex strategy: vertical only for narrow windows that
  # still have enough lines; otherwise keep the horizontal layout.
  if [[ "$width" =~ ^[0-9]+$ && "$height" =~ ^[0-9]+$ ]] \
    && (( width < FLEX_FLIP_COLUMNS && height >= FLEX_FLIP_LINES )); then
    printf '%s\n' 'down,50%,border-top,wrap,follow'
    return
  fi

  printf '%s\n' 'right,50%,border-left,wrap,follow'
}

# --- Batch AI process detection (Claude Code + Codex) ---
# One pgrep per tool + one ps call replaces O(n_panes) pgrep invocations.
declare -A AI_PANE_PIDS   # pid -> 1
declare -A AI_PANE_TOOL   # pid -> claude|codex (for fallback label)
_build_ai_pids() {
  # Collect PIDs per tool in one pass (avoids redundant pgrep calls).
  local -A tool_pids_map
  local found=0
  for tool in claude codex; do
    local pids
    pids=$(pgrep -x "$tool" 2>/dev/null) || continue
    tool_pids_map[$tool]="$pids"
    found=1
  done
  (( found )) || return 0

  # Build pid -> ppid map from the full process table.
  local -A ppid_map
  while read -r pid ppid; do
    [[ -n "$pid" ]] && ppid_map[$pid]=$ppid
  done < <(ps -eo pid=,ppid= 2>/dev/null)

  # Map each tool's pids to their parent/grandparent pane pids.
  local cpid parent grandparent
  for tool in claude codex; do
    [[ -n "${tool_pids_map[$tool]:-}" ]] || continue
    for cpid in ${tool_pids_map[$tool]}; do
      parent="${ppid_map[$cpid]:-}"
      [[ -z "$parent" ]] && continue
      AI_PANE_PIDS[$parent]=1
      AI_PANE_TOOL[$parent]="$tool"
      # grandparent covers shell -> wrapper -> tool.
      grandparent="${ppid_map[$parent]:-}"
      if [[ -n "$grandparent" ]]; then
        AI_PANE_PIDS[$grandparent]=1
        AI_PANE_TOOL[$grandparent]="$tool"
      fi
    done
  done
}
_build_ai_pids

# Resolve status from _marker_fields (must call _read_marker first).
# Sets _status_color and _status_icon to avoid subshell forks.
_status_color=""
_status_icon=""
_normalized_title=""
_resolve_status() {
  local marker="$1"
  local ts="${_marker_fields[timestamp]:-}"

  # Stale marker — remove and treat as default (no icon).
  if [[ -n "$ts" ]] && (( NOW - ts > TTL )); then
    rm -f "$marker"
    _status_color=""; _status_icon=""
    return
  fi

  case "${_marker_fields[notification_type]:-}" in
    permission_prompt|elicitation_dialog)
      _status_color="$MAROON"; _status_icon="󰂞" ;;
    ask_user_question)
      _status_color="$FLAMINGO"; _status_icon="󰘥" ;;
    plan_approval)
      _status_color="$TEAL"; _status_icon="󰝖" ;;
    idle_prompt|"")
      _status_color="$LAVENDER"; _status_icon="󰏤" ;;
    *)
      _status_color="$MAROON"; _status_icon="󰀦" ;;
  esac
}

_normalize_codex_title() {
  local title="$1"

  if [[ "$title" == "[!] Action Required | "* ]]; then
    [[ -z "$_status_icon" ]] && { _status_color="$MAROON"; _status_icon="󰂞"; }
    title="${title#"[!] Action Required | "}"
  elif [[ "$title" == \[*\]\ *\|\ * ]]; then
    title="${title#*] }"
    title="${title#*| }"
  elif [[ "$title" == \[*\]\ * ]]; then
    title="${title#*] }"
  fi
  [[ "$title" == [![:alnum:]]" "* ]] && title="${title#? }"

  _normalized_title="$title"
}

# Switch to a pane (works across tmux sessions).
switch_to_pane() {
  local pane_id="$1"
  local session
  session=$(tmux display-message -t "$pane_id" -p '#{session_name}' 2>/dev/null || true)
  [[ -n "$session" ]] && tmux switch-client -t "$session" 2>/dev/null || true
  tmux select-pane -t "$pane_id" 2>/dev/null || true
}

# --- Pass 1: Identify AI panes (fast hash lookup, no subprocess per pane) ---
declare -a ai_panes=()
while IFS=$'\t' read -r pane_id session_name win_idx pane_idx pane_pid pane_path pane_title; do
  [[ -n "${AI_PANE_PIDS[$pane_pid]:-}" ]] || continue
  ai_panes+=("${pane_id}	${session_name}	${win_idx}	${pane_idx}	${pane_pid}	${pane_path}	${pane_title}")
  (( ${#ai_panes[@]} >= MAX_SESSIONS )) && break
done < <(tmux list-panes -a -F "#{pane_id}	#{session_name}	#{window_index}	#{pane_index}	#{pane_pid}	#{pane_current_path}	#{pane_title}")

if [[ ${#ai_panes[@]} -eq 0 ]]; then
  echo "No Claude Code or Codex sessions found."
  sleep 1
  exit 0
fi

# --- Pass 2: Gather git info in parallel ---
GIT_TMPDIR=$(mktemp -d)
trap 'rm -rf "$GIT_TMPDIR"' EXIT

for entry in "${ai_panes[@]}"; do
  IFS=$'\t' read -r pane_id _ _ _ _ pane_path _ <<< "$entry"
  (
    branch=""
    git_status=$(git -C "$pane_path" status --porcelain -b --short -uno 2>/dev/null || true)
    if [[ -n "$git_status" ]]; then
      IFS=$'\n' read -r header _ <<< "$git_status"
      branch="${header#\#\# }"
      branch="${branch%%...*}"
      branch="${branch%% \[*}"
      if [[ "$branch" == "HEAD (no branch)" ]]; then
        branch=$(git -C "$pane_path" rev-parse --short HEAD 2>/dev/null || true)
      fi
      if [[ "$git_status" == *$'\n'* ]]; then
        branch="${branch}*"
      fi
    fi
    printf '%s\n' "$branch" > "${GIT_TMPDIR}/${pane_id}"
  ) &
done
wait

# --- Pass 3: Assemble single-line display entries ---
# Format: [status] [tool] project  session:win.pane  branch*
declare -a blocks=()
declare -a pane_ids_arr=()
declare -a priorities=()
for entry in "${ai_panes[@]}"; do
  IFS=$'\t' read -r pane_id session_name win_idx pane_idx pane_pid pane_path pane_title <<< "$entry"

  branch=""
  [[ -f "${GIT_TMPDIR}/${pane_id}" ]] && IFS= read -r branch < "${GIT_TMPDIR}/${pane_id}"

  # Read marker once — _resolve_status and project lookup share _marker_fields.
  # Check tool-specific attention dir based on detected process type.
  tool="${AI_PANE_TOOL[$pane_pid]:-claude}"
  if [[ "$tool" == "codex" ]]; then
    marker="${ATTN_DIR_CODEX}/${pane_id}"
  else
    marker="${ATTN_DIR_CLAUDE}/${pane_id}"
  fi
  if [[ -f "$marker" ]]; then
    _read_marker "$marker"
    _resolve_status "$marker"
  else
    _marker_fields=()
    _status_color=""; _status_icon=""
  fi

  # Project name priority: pane title (set by Claude Code) > marker > dir basename.
  # Claude Code sets pane_title to "[status] session-name"; strip the leading icon.
  project=""
  if [[ -n "$pane_title" ]]; then
    # Strip leading non-alphanumeric status icon + space (e.g., "✳ ", "⠂ ").
    local_title="$pane_title"
    if [[ "$tool" == "codex" ]]; then
      _normalize_codex_title "$local_title"
      local_title="$_normalized_title"
    elif [[ "$pane_title" == [![:alnum:]]" "* ]]; then
      local_title="${pane_title#? }"
    fi
    # Skip hostname or generic "Claude Code" — not useful as a project name.
    case "$local_title" in
      *.local|"Claude Code"|"Codex") ;;
      ?*) project="$local_title" ;;
    esac
  fi
  [[ -z "$project" ]] && project="${_marker_fields[project]:-}"
  [[ -z "$project" ]] && project="${pane_path##*/}"
  if [[ -z "$project" ]]; then
    case "$tool" in
      codex) project="Codex" ;;
      *)     project="Claude Code" ;;
    esac
  fi

  label="${session_name}:${win_idx}.${pane_idx}"

  # Status priority: 0=needs attention (maroon), 1=question/plan (flamingo/teal),
  # 2=idle (lavender), 3=running (no icon).
  priority=3
  case "$_status_color" in
    "$MAROON")   priority=0 ;;
    "$FLAMINGO") priority=1 ;;
    "$TEAL")     priority=1 ;;
    "$LAVENDER") priority=2 ;;
  esac

  # Tool icon with brand color.
  if [[ "$tool" == "codex" ]]; then
    tool_icon="${CODEX_TEAL}${ICON_CODEX}${RESET}"
  else
    tool_icon="${CLAUDE_PEACH}${ICON_CLAUDE}${RESET}"
  fi

  if [[ -n "$_status_icon" ]]; then
    line="${_status_color}${_status_icon}${RESET} ${tool_icon} ${BOLD}${WHITE}${project}${RESET}"
  else
    line="${tool_icon} ${BOLD}${WHITE}${project}${RESET}"
  fi
  line+=" ${TMUX_GREEN} ${label}${RESET}"
  if [[ -n "$branch" ]]; then
    line+=" ${RED} ${branch}${RESET}"
  fi

  blocks+=("${pane_id}	${line}")
  pane_ids_arr+=("$pane_id")
  priorities+=("$priority")
done

# Sort indices by priority (stable via -s).
sorted_indices=()
while read -r idx _; do
  sorted_indices+=("$idx")
done < <(for i in "${!priorities[@]}"; do printf '%s %s\n' "$i" "${priorities[$i]}"; done | sort -s -k2,2n)

if [[ ${#blocks[@]} -eq 1 ]]; then
  switch_to_pane "${pane_ids_arr[0]}"
  exit 0
fi

preview_window=$(_preview_window_layout)

# Feed single-line entries to fzf (pane_id\tdisplay, hidden via --with-nth).
selected=$(for i in "${sorted_indices[@]}"; do printf '%s\n' "${blocks[$i]}"; done | fzf \
  --ansi \
  --delimiter=$'\t' \
  --with-nth=2 \
  --exact \
  --highlight-line \
  --reverse \
  --no-sort \
  --no-scrollbar \
  --info=hidden \
  --preview='tmux capture-pane -t {1} -p -e -S -200 2>/dev/null || echo "(pane unavailable)"' \
  --preview-window="$preview_window" \
  --preview-label=' Preview ' \
  --preview-label-pos=2) || exit 0

# Extract pane_id from the hidden first tab-delimited field.
pane_id="${selected%%$'\t'*}"
switch_to_pane "$pane_id"
