{
  "layer": "top",
  "position": "top",
  "reload_style_on_change": true,
  "modules-left": [],
  "modules-center": ["clock", "mpris", "hyprland/workspaces", "pulseaudio", "network"],
  "modules-right": [],
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": 5
    }
  },
  "network": {
    "format-wifi": "",
    "format-ethernet": "",
    "format-disconnected": "",
    "tooltip-format-wifi": "{ifname} {essid} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "Disconnected"
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "",
    "format-icons": {
      "default": ["", "", ""]
    },
    "tooltip-format": "{volume}%",
    "on-click": "pavucontrol"
  },
  "mpris": {
    "format": "{status_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "format-stopped": "",
    "dynamic-order": ["title", "artist"],
    "dynamic-len": 28,
    "title-len": 24,
    "artist-len": 18,
    "album-len": 0,
    "status-icons": {
      "playing": "",
      "paused": "",
      "stopped": ""
    },
    "tooltip-format": "{player}: {dynamic}"
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d %b %H:%M}"
  }
}
