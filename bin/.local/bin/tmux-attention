#!/usr/bin/env bash
# tmux-attention: jump to tmux pane(s) needing Claude Code user attention.
# Invoked via tmux keybinding (Prefix+a).
# Usage:
#   tmux-attention                -- dispatch: 0 msg, 1 direct, N cycle to most urgent
#   tmux-attention --pick         -- picker: fzf selection with pane preview
#   tmux-attention --clear-focused -- auto-dismiss: clear marker for focused pane

# _attn_* globals are set by resolve_attention() in the sourced lib.
# shellcheck disable=SC2154
set -euo pipefail

ATTN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude/attention"
TTL=300 # 5 minutes

# shellcheck source=tmux-attention-lib
source "$(dirname "$0")/tmux-attention-lib"

# --- Helpers ---

# Read a single field from a marker file (used for isolated lookups).
read_field() {
  grep "^${1}=" "$2" 2>/dev/null | cut -d= -f2-
}

# Read all fields from a marker file into associative array _marker_fields.
# Usage: read_marker "$file"; echo "${_marker_fields[pane_id]}"
declare -A _marker_fields=()
read_marker() {
  _marker_fields=()
  while IFS='=' read -r key val; do
    _marker_fields[$key]="$val"
  done < "$1"
}

# Clear pane border style and recompute window @attention from remaining markers.
clear_pane_attention() {
  local cleared_pane="$1"
  tmux set-option -p -u -t "$cleared_pane" pane-border-style 2>/dev/null || true

  local window_id
  window_id=$(tmux display-message -t "$cleared_pane" -p '#{window_id}' 2>/dev/null || true)
  recompute_window_attention "$window_id" "$cleared_pane"
}

# Collect valid (non-stale, pane-alive) marker paths, one per line.
collect_markers() {
  [[ -d "$ATTN_DIR" ]] || return 0

  local now marker ts pane_id
  now=$(date +%s)

  for marker in "$ATTN_DIR"/%*; do
    [[ -f "$marker" ]] || continue

    read_marker "$marker"
    ts="${_marker_fields[timestamp]:-}"
    pane_id="${_marker_fields[pane_id]:-}"

    # Stale marker -- remove.
    if [[ -n "$ts" ]] && (( now - ts > TTL )); then
      rm -f "$marker"
      continue
    fi

    # Pane no longer exists -- remove.
    if [[ -z "$pane_id" ]] || ! tmux display-message -t "$pane_id" -p '' >/dev/null 2>&1; then
      rm -f "$marker"
      continue
    fi

    printf '%s\n' "$marker"
  done
}

# Switch to a pane (works across tmux sessions).
# Queries tmux directly for the session name to handle sessions with colons.
switch_to_pane() {
  local pane_id="$1" marker="$2"
  local session
  session=$(tmux display-message -t "$pane_id" -p '#{session_name}' 2>/dev/null || true)

  if [[ -n "$session" ]]; then
    tmux switch-client -t "$session" 2>/dev/null || true
  fi
  tmux select-pane -t "$pane_id" 2>/dev/null || true

  rm -f "$marker"
  clear_pane_attention "$pane_id"
}

# Sort marker paths by priority (then timestamp for tie-breaking).
# Reads paths from stdin, writes sorted paths to stdout.
sort_markers() {
  local markers=()
  while IFS= read -r m; do
    [[ -n "$m" ]] && markers+=("$m")
  done

  [[ ${#markers[@]} -eq 0 ]] && return 0

  local m ntype ts
  for m in "${markers[@]}"; do
    read_marker "$m"
    ntype="${_marker_fields[notification_type]:-}"
    ts="${_marker_fields[timestamp]:-}"
    resolve_attention "$ntype"
    printf '%s\t%s\t%s\n' "$_attn_priority" "$ts" "$m"
  done | sort -t$'\t' -k1,1n -k2,2n | cut -f3
}

# Format a marker for fzf display. Output: "display_text\tpane_id\tmarker_path"
# Uses ANSI-colored Nerd Font icons (Catppuccin Mocha palette).
format_marker() {
  local marker="$1"
  local pane_label ntype project pane_id

  read_marker "$marker"
  pane_label="${_marker_fields[pane_label]:-}"
  ntype="${_marker_fields[notification_type]:-}"
  project="${_marker_fields[project]:-}"
  pane_id="${_marker_fields[pane_id]:-}"

  resolve_attention "$ntype"

  local display
  if [[ -n "$_attn_color" ]]; then
    # ANSI 24-bit color: \e[38;2;R;G;Bm ... \e[0m
    local r g b
    r=$(( 16#${_attn_color:1:2} ))
    g=$(( 16#${_attn_color:3:2} ))
    b=$(( 16#${_attn_color:5:2} ))
    display=$(printf '\033[38;2;%d;%d;%dm%s\033[0m %s (%s)' "$r" "$g" "$b" "$_attn_icon" "$project" "$pane_label")
  else
    display=$(printf '  %s (%s)' "$project" "$pane_label")
  fi

  printf '%s\t%s\t%s\n' "$display" "$pane_id" "$marker"
}

# === CLEAR-FOCUSED MODE (called from pane-focus-in hook) ===
if [[ "${1:-}" == "--clear-focused" ]]; then
  [[ -d "$ATTN_DIR" ]] || exit 0
  pane_id=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
  if [[ -n "$pane_id" && -f "${ATTN_DIR}/${pane_id}" ]]; then
    rm -f "${ATTN_DIR}/${pane_id}"
    clear_pane_attention "$pane_id"
  fi
  exit 0
fi

# === PICKER MODE (called inside display-popup with a TTY) ===
if [[ "${1:-}" == "--pick" ]]; then
  markers=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && markers+=("$line")
  done < <(collect_markers | sort_markers)

  if [[ ${#markers[@]} -eq 0 ]]; then
    echo "No panes need attention."
    sleep 1
    exit 0
  fi

  if [[ ${#markers[@]} -eq 1 ]]; then
    pane_id=$(read_field pane_id "${markers[0]}")
    switch_to_pane "$pane_id" "${markers[0]}"
    exit 0
  fi

  selected=$(for marker in "${markers[@]}"; do format_marker "$marker"; done | fzf \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --header="Select pane needing attention" \
    --reverse \
    --no-sort \
    --preview='tmux capture-pane -t {2} -p -S -10 2>/dev/null || echo "(pane unavailable)"' \
    --preview-window=down:12:wrap) || exit 0

  if [[ -n "$selected" ]]; then
    pane_id=$(printf '%s' "$selected" | cut -f2)
    marker_path=$(printf '%s' "$selected" | cut -f3)
    switch_to_pane "$pane_id" "$marker_path"
  fi
  exit 0
fi

# === DISPATCH MODE (called from run-shell, no TTY) ===
markers=()
while IFS= read -r line; do
  [[ -n "$line" ]] && markers+=("$line")
done < <(collect_markers | sort_markers)

count=${#markers[@]}

case "$count" in
  0)
    tmux display-message "No panes need attention"
    ;;
  1)
    pane_id=$(read_field pane_id "${markers[0]}")
    switch_to_pane "$pane_id" "${markers[0]}"
    ;;
  *)
    # Switch to the most urgent pane; use Prefix+A for the full picker.
    pane_id=$(read_field pane_id "${markers[0]}")
    switch_to_pane "$pane_id" "${markers[0]}"
    ;;
esac
