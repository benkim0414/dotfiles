{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "NotebookRead",
      "Write",
      "Edit",
      "MultiEdit",
      "NotebookEdit",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Agent",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "Skill",
      "ToolSearch",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "CronList",
      "mcp__sequential-thinking__*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "MultiEdit(.env)",
      "MultiEdit(.env.*)",
      "MultiEdit(**/.env)",
      "MultiEdit(**/.env.*)",
      "Read(~/.ssh/*)",
      "Write(~/.ssh/*)",
      "Edit(~/.ssh/*)",
      "MultiEdit(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Write(~/.gnupg/*)",
      "Edit(~/.gnupg/*)",
      "MultiEdit(~/.gnupg/*)",
      "Read(~/.aws/credentials)",
      "Write(~/.aws/credentials)",
      "Edit(~/.aws/credentials)",
      "MultiEdit(~/.aws/credentials)",
      "Read(~/.claude/.credentials.json)",
      "Write(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "MultiEdit(~/.claude/.credentials.json)",
      "Read(~/.kube/config)",
      "Write(~/.kube/config)",
      "Edit(~/.kube/config)",
      "MultiEdit(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Write(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "MultiEdit(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Write(~/.netrc)",
      "Edit(~/.netrc)",
      "MultiEdit(~/.netrc)",
      "Read(~/.config/gh/hosts.yml)",
      "Write(~/.config/gh/hosts.yml)",
      "Edit(~/.config/gh/hosts.yml)",
      "MultiEdit(~/.config/gh/hosts.yml)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo archive *)",
      "Bash(gh release delete *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue delete *)",
      "Bash(gh run cancel *)",
      "Bash(gh workflow disable *)",
      "Bash(gh cache delete *)",
      "Bash(gh secret delete *)",
      "Bash(gh variable delete *)",
      "Bash(gh label delete *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh api -X DELETE *)",
      "Bash(kubectl delete *)",
      "Bash(terraform destroy*)",
      "Bash(helm uninstall *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm *)",
      "Bash(docker network rm *)",
      "CronCreate",
      "CronDelete",
      "RemoteTrigger"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/git-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bash-pretool.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/worktree-guard.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/worktree-entered.sh"
          }
        ]
      },
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/worktree-exited.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "CronCreate|CronDelete|RemoteTrigger",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "atomic-agents@claude-plugins-official": true,
    "remember@claude-plugins-official": true
  }
}
