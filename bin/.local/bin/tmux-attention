#!/usr/bin/env bash
# tmux-attention: jump to tmux pane(s) needing Claude Code user attention.
# Invoked via tmux keybinding (Prefix+a).
# Usage:
#   tmux-attention                -- dispatch: 0 msg, 1 direct, N cycle to most urgent
#   tmux-attention --pick         -- picker: fzf selection with pane preview
#   tmux-attention --clear-focused -- auto-dismiss: clear marker for focused pane
set -euo pipefail

ATTN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude/attention"
TTL=300 # 5 minutes

# --- Helpers ---

# Read a single field from a marker file.
read_field() {
  grep "^${1}=" "$2" 2>/dev/null | cut -d= -f2-
}

# Collect valid (non-stale, pane-alive) marker paths, one per line.
collect_markers() {
  [[ -d "$ATTN_DIR" ]] || return 0

  local now marker ts pane_id
  now=$(date +%s)

  for marker in "$ATTN_DIR"/%*; do
    [[ -f "$marker" ]] || continue

    ts=$(read_field timestamp "$marker")
    pane_id=$(read_field pane_id "$marker")

    # Stale marker -- remove.
    if [[ -n "$ts" ]] && (( now - ts > TTL )); then
      rm -f "$marker"
      continue
    fi

    # Pane no longer exists -- remove.
    if [[ -z "$pane_id" ]] || ! tmux display-message -t "$pane_id" -p '' >/dev/null 2>&1; then
      rm -f "$marker"
      continue
    fi

    printf '%s\n' "$marker"
  done
}

# Switch to a pane (works across tmux sessions).
# Queries tmux directly for the session name to handle sessions with colons.
switch_to_pane() {
  local pane_id="$1" marker="$2"
  local session
  session=$(tmux display-message -t "$pane_id" -p '#{session_name}' 2>/dev/null || true)

  if [[ -n "$session" ]]; then
    tmux switch-client -t "$session" 2>/dev/null || true
  fi
  tmux select-pane -t "$pane_id" 2>/dev/null || true

  rm -f "$marker"
}

# Return numeric priority for a notification type (lower = more urgent).
ntype_priority() {
  case "$(read_field notification_type "$1")" in
    permission_prompt)  echo 1 ;;
    plan_approval)      echo 2 ;;
    ask_user_question)  echo 3 ;;
    elicitation_dialog) echo 4 ;;
    idle_prompt)        echo 5 ;;
    *)                  echo 9 ;;
  esac
}

# Sort marker paths by priority (then timestamp for tie-breaking).
# Reads paths from stdin, writes sorted paths to stdout.
sort_markers() {
  local markers=()
  while IFS= read -r m; do
    [[ -n "$m" ]] && markers+=("$m")
  done

  [[ ${#markers[@]} -eq 0 ]] && return 0

  local m
  for m in "${markers[@]}"; do
    printf '%s\t%s\t%s\n' "$(ntype_priority "$m")" "$(read_field timestamp "$m")" "$m"
  done | sort -t$'\t' -k1,1n -k2,2n | cut -f3
}

# Format a marker for fzf display. Output: "display_text\tpane_id\tmarker_path"
format_marker() {
  local marker="$1"
  local pane_label ntype project pane_id label

  pane_label=$(read_field pane_label "$marker")
  ntype=$(read_field notification_type "$marker")
  project=$(read_field project "$marker")
  pane_id=$(read_field pane_id "$marker")

  case "$ntype" in
    permission_prompt)  label="Approval" ;;
    idle_prompt)        label="Complete" ;;
    elicitation_dialog) label="Input" ;;
    ask_user_question)  label="Question" ;;
    plan_approval)      label="Plan" ;;
    *)                  label="$ntype" ;;
  esac

  printf '[%s] %s (%s)\t%s\t%s\n' "$label" "$project" "$pane_label" "$pane_id" "$marker"
}

# === CLEAR-FOCUSED MODE (called from pane-focus-in hook) ===
if [[ "${1:-}" == "--clear-focused" ]]; then
  [[ -d "$ATTN_DIR" ]] || exit 0
  pane_id=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
  [[ -n "$pane_id" ]] && rm -f "${ATTN_DIR}/${pane_id}"
  exit 0
fi

# === PICKER MODE (called inside display-popup with a TTY) ===
if [[ "${1:-}" == "--pick" ]]; then
  markers=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && markers+=("$line")
  done < <(collect_markers | sort_markers)

  if [[ ${#markers[@]} -eq 0 ]]; then
    echo "No panes need attention."
    sleep 1
    exit 0
  fi

  if [[ ${#markers[@]} -eq 1 ]]; then
    pane_id=$(read_field pane_id "${markers[0]}")
    switch_to_pane "$pane_id" "${markers[0]}"
    exit 0
  fi

  selected=$(for marker in "${markers[@]}"; do format_marker "$marker"; done | fzf \
    --delimiter=$'\t' \
    --with-nth=1 \
    --header="Select pane needing attention" \
    --reverse \
    --no-sort \
    --preview='tmux capture-pane -t {2} -p -S -10 2>/dev/null || echo "(pane unavailable)"' \
    --preview-window=down:12:wrap) || exit 0

  if [[ -n "$selected" ]]; then
    pane_id=$(printf '%s' "$selected" | cut -f2)
    marker_path=$(printf '%s' "$selected" | cut -f3)
    switch_to_pane "$pane_id" "$marker_path"
  fi
  exit 0
fi

# === DISPATCH MODE (called from run-shell, no TTY) ===
markers=()
while IFS= read -r line; do
  [[ -n "$line" ]] && markers+=("$line")
done < <(collect_markers | sort_markers)

count=${#markers[@]}

case "$count" in
  0)
    tmux display-message "No panes need attention"
    ;;
  1)
    pane_id=$(read_field pane_id "${markers[0]}")
    switch_to_pane "$pane_id" "${markers[0]}"
    ;;
  *)
    # Switch to the most urgent pane; use Prefix+A for the full picker.
    pane_id=$(read_field pane_id "${markers[0]}")
    switch_to_pane "$pane_id" "${markers[0]}"
    ;;
esac
