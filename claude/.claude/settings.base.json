{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_COST_WARNINGS": "1"
  },
  "model": "opus[1m]",
  "theme": "custom:catppuccin",
  "effortLevel": "auto",
  "defaultMode": "auto",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "NotebookRead",
      "Write",
      "Edit",
      "NotebookEdit",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Agent",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "Skill",
      "ToolSearch",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "CronList",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_doctor",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_index",
      "mcp__plugin_context-mode_context-mode__ctx_insight",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__plugin_context-mode_context-mode__ctx_stats",
      "mcp__playwright__*"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Read(~/.ssh/*)",
      "Edit(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Edit(~/.gnupg/*)",
      "Read(~/.aws/credentials)",
      "Edit(~/.aws/credentials)",
      "Read(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "Read(~/.kube/config)",
      "Edit(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Edit(~/.netrc)",
      "Read(~/.config/gh/hosts.yml)",
      "Edit(~/.config/gh/hosts.yml)",
      "Bash(*~/.ssh/id_rsa)",
      "Bash(*~/.ssh/id_ecdsa)",
      "Bash(*~/.ssh/id_ecdsa_sk)",
      "Bash(*~/.ssh/id_ed25519)",
      "Bash(*~/.ssh/id_ed25519_sk)",
      "Bash(*~/.ssh/id_dsa)",
      "Bash(*~/.ssh/config*)",
      "Bash(*~/.gnupg/private*)",
      "Bash(*~/.aws/credentials*)",
      "Bash(*~/.claude/.credentials*)",
      "Bash(*~/.kube/config*)",
      "Bash(*~/.docker/config.json*)",
      "Bash(*~/.netrc*)",
      "Bash(*~/.config/gh/hosts.yml*)",
      "Bash(bw get *)",
      "Bash(bw list *)",
      "Bash(bw export*)",
      "Bash(bw export --*)",
      "Bash(op read *)",
      "Bash(op item get *)",
      "Bash(op document get *)",
      "Bash(op item edit *)",
      "Bash(op vault export*)",
      "Bash(*$HOME/.ssh/id_rsa*)",
      "Bash(*$HOME/.ssh/id_ed25519*)",
      "Bash(*$HOME/.ssh/id_ecdsa*)",
      "Bash(*$HOME/.aws/credentials*)",
      "Bash(*$HOME/.claude/.credentials*)",
      "Bash(*/Users/ben/.ssh/id_rsa*)",
      "Bash(*/Users/ben/.ssh/id_ed25519*)",
      "Bash(*/Users/ben/.aws/credentials*)",
      "Bash(*/Users/ben/.claude/.credentials*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo archive *)",
      "Bash(gh release delete *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue close *)",
      "Bash(gh issue lock *)",
      "Bash(gh issue delete *)",
      "Bash(gh run cancel *)",
      "Bash(gh workflow disable *)",
      "Bash(gh cache delete *)",
      "Bash(gh secret delete *)",
      "Bash(gh variable delete *)",
      "Bash(gh label delete *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh api -X DELETE *)",
      "Bash(kubectl delete *)",
      "Bash(terraform destroy*)",
      "Bash(helm uninstall *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm *)",
      "Bash(docker network rm *)",
      "Bash(pip install *)",
      "Bash(npm install -g *)",
      "Bash(cargo install *)",
      "Bash(go install *)",
      "Bash(curl * -X POST*)",
      "Bash(curl * -X PUT*)",
      "Bash(curl * -X DELETE*)",
      "Bash(curl * -X PATCH*)",
      "Bash(curl * --request POST*)",
      "Bash(curl * --request PUT*)",
      "Bash(curl * --request DELETE*)",
      "Bash(curl * -d *)",
      "Bash(curl * --data*)",
      "Bash(wget --post-*)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(git config *)",
      "Bash(git filter-repo*)",
      "Bash(git filter-branch*)",
      "Bash(git rebase -i*)",
      "Bash(git push origin main*)",
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(npm publish*)",
      "Bash(cargo publish*)",
      "Bash(twine upload*)",
      "Bash(gem push*)",
      "Bash(gh api * -X POST*)",
      "Bash(gh api * -X PUT*)",
      "Bash(gh api * -X PATCH*)",
      "Bash(gh api --method POST*)",
      "Bash(gh api --method PUT*)",
      "Bash(gh api --method PATCH*)",
      "CronCreate",
      "CronDelete",
      "RemoteTrigger",
      "mcp__*__*delete*",
      "mcp__*__*remove*",
      "mcp__*__*sync*",
      "mcp__*__*deploy*",
      "mcp__*__*apply*",
      "mcp__*__*patch*",
      "mcp__*__*write*",
      "mcp__plugin_context-mode_context-mode__ctx_purge",
      "mcp__plugin_context-mode_context-mode__ctx_upgrade"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/git-session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/resolve-pr-refs.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|NotebookRead|mcp__qmd__get|Bash|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/read-once.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/git-safety.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/worktree-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/permission-policy.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/worktree-entered.sh"
          }
        ]
      },
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/worktree-exited.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|CronCreate|CronDelete|RemoteTrigger|Read|NotebookRead|Grep|mcp__qmd__get|mcp__qmd__multi_get",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/failure-recovery.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/restore-git-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/read-once-gc.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "claude-md-management@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true,
    "context-mode@context-mode": true,
    "insane-search@gptaku-plugins": true,
    "superpowers@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": { "source": "github", "repo": "JuliusBrussee/caveman" },
      "autoUpdate": true
    },
    "compound-engineering-plugin": {
      "source": { "source": "github", "repo": "EveryInc/compound-engineering-plugin" },
      "autoUpdate": true
    },
    "context-mode": {
      "source": { "source": "github", "repo": "mksglu/context-mode" },
      "autoUpdate": true
    },
    "gptaku-plugins": {
      "source": { "source": "github", "repo": "fivetaku/gptaku_plugins" },
      "autoUpdate": true
    },
    "superpowers-marketplace": {
      "source": { "source": "github", "repo": "obra/superpowers-marketplace" },
      "autoUpdate": true
    }
  }
}
