#!/usr/bin/env bash
# tmux-attention-lib: shared functions for tmux attention indicator scripts.
# Sourced by: tmux-attention, tmux-attention-badge, notify.sh
#
# Provides:
#   resolve_attention <ntype>  -- sets _attn_color, _attn_icon, _attn_priority
#   recompute_window_attention <window_id> [<exclude_pane>]
#                              -- recompute @attention* options from surviving markers

# Globals set by resolve_attention (exported for shellcheck visibility).
_attn_color=""
_attn_icon=""
_attn_priority=9

# Attention directory (caller may override before sourcing).
: "${ATTN_DIR:=${XDG_CACHE_HOME:-$HOME/.cache}/claude/attention}"

# Resolve attention color and icon for a notification type.
# Sets globals: _attn_color, _attn_icon, _attn_priority (Catppuccin Mocha palette).
# idle_prompt gets no visual treatment (empty color/icon).
resolve_attention() {
  _attn_color=""; _attn_icon=""; _attn_priority=9
  case "$1" in
    permission_prompt)  _attn_color="#f38ba8"; _attn_icon=""; _attn_priority=1 ;;
    plan_approval)      _attn_color="#fab387"; _attn_icon=""; _attn_priority=2 ;;
    ask_user_question)  _attn_color="#fab387"; _attn_icon=""; _attn_priority=3 ;;
    elicitation_dialog) _attn_color="#fab387"; _attn_icon="󰏫"; _attn_priority=4 ;;
    idle_prompt)        _attn_priority=5 ;;
  esac
}

# Recompute window @attention options from surviving non-idle markers.
# Args: $1 = window_id, $2 = pane_id to exclude (optional, e.g. the one being cleared)
recompute_window_attention() {
  local window_id="$1" exclude_pane="${2:-}"
  [[ -n "$window_id" ]] || return 0

  local best_pri=99 best_color="" best_icon=""
  local f other_pane other_ntype other_window
  for f in "$ATTN_DIR"/%*; do
    [[ -f "$f" ]] || continue
    other_pane=$(grep "^pane_id=" "$f" 2>/dev/null | cut -d= -f2-)
    [[ -n "$other_pane" ]] || continue
    [[ -z "$exclude_pane" || "$other_pane" != "$exclude_pane" ]] || continue

    other_window=$(tmux display-message -t "$other_pane" -p '#{window_id}' 2>/dev/null || true)
    [[ "$other_window" == "$window_id" ]] || continue

    other_ntype=$(grep "^notification_type=" "$f" 2>/dev/null | cut -d= -f2-)
    resolve_attention "$other_ntype"
    [[ -n "$_attn_color" ]] || continue
    if (( _attn_priority < best_pri )); then
      best_pri=$_attn_priority
      best_color=$_attn_color
      best_icon=$_attn_icon
    fi
  done

  if [[ -n "$best_color" ]]; then
    tmux set-option -w -t "$window_id" @attention "1" 2>/dev/null || true
    tmux set-option -w -t "$window_id" @attention_color "$best_color" 2>/dev/null || true
    tmux set-option -w -t "$window_id" @attention_icon "$best_icon" 2>/dev/null || true
    tmux set-option -w -t "$window_id" @attention_priority "$best_pri" 2>/dev/null || true
  else
    tmux set-option -w -u -t "$window_id" @attention 2>/dev/null || true
    tmux set-option -w -u -t "$window_id" @attention_color 2>/dev/null || true
    tmux set-option -w -u -t "$window_id" @attention_icon 2>/dev/null || true
    tmux set-option -w -u -t "$window_id" @attention_priority 2>/dev/null || true
  fi
}
