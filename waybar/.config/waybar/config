{
  "layer": "top",
  "position": "top",
  "reload_style_on_change": true,
  "modules-left": [],
  "modules-center": ["clock", "tray", "mpris", "hyprland/workspaces", "pulseaudio", "bluetooth", "custom/network"],
  "modules-right": [],
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": 5
    }
  },
  "custom/network": {
    "exec": "sh $HOME/.config/waybar/scripts/network-status",
    "interval": 10,
    "on-click": "env XDG_CURRENT_DESKTOP=GNOME XDG_SESSION_DESKTOP=gnome gnome-control-center wifi",
    "return-type": "json",
    "tooltip": true
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "󰝟",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "tooltip-format": "{volume}%",
    "on-click": "pavucontrol"
  },
  "bluetooth": {
    "format": "",
    "format-disabled": "",
    "format-off": "",
    "format-on": "",
    "format-connected": "",
    "format-no-controller": "",
    "max-length": 18,
    "on-click": "blueman-manager",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
  },
  "mpris": {
    "format": "{status_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "format-stopped": "",
    "dynamic-order": ["title", "artist"],
    "dynamic-len": 28,
    "title-len": 24,
    "artist-len": 18,
    "album-len": 0,
    "status-icons": {
      "playing": "",
      "paused": "",
      "stopped": ""
    },
    "tooltip-format": "{player}: {dynamic}"
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d %b %H:%M}"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}
