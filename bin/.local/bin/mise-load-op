#!/usr/bin/env bash
set -euo pipefail
# Resolve 1Password secrets from a .env.op file and write them to .env.local.
# Designed for mise [tasks]: run once, then load the cached file via [env] _.file.
#
# .env.op format -- each non-comment line:
#   VAR_NAME=op://vault/item/field
#
# Usage in .mise.toml:
#   [env]
#   _.file = [".env.local"]
#   [tasks.secrets]
#   run = "mise-load-op"

env_file="${1:-.env.op}"
out_file="${2:-.env.local}"

[[ -f "$env_file" ]] || { echo "mise-load-op: ${env_file} not found" >&2; exit 1; }

# Collect variable names defined in the env file so we only capture those.
declare -a var_names=()
while IFS='=' read -r key _; do
  [[ "$key" =~ ^[[:space:]]*# ]] && continue
  [[ -z "${key// /}" ]] && continue
  var_names+=("$key")
done < "$env_file"

(( ${#var_names[@]} )) || { echo "mise-load-op: no variables in ${env_file}" >&2; exit 1; }

: > "$out_file"

# op run resolves secret references and injects them into the command's env.
# --no-masking is required to capture plaintext values (op redacts by default).
while IFS= read -r -d '' line; do
  key="${line%%=*}"
  for name in "${var_names[@]}"; do
    if [[ "$key" == "$name" ]]; then
      printf '%s\n' "$line" >> "$out_file"
      break
    fi
  done
done < <(op run --env-file="$env_file" --no-masking -- env -0)

chmod 600 "$out_file"
echo "Wrote secrets to ${out_file}"
