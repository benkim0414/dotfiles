#!/usr/bin/env bash
# tmux-claude-picker: show all Claude Code sessions with status info.
# Displayed in a tmux popup via Prefix+A.
# Shows directory, git branch, and Claude status for each pane running Claude Code.
set -euo pipefail

MAX_SESSIONS=10

ATTN_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude/attention"
TTL=300 # 5 minutes
NOW=$(date +%s)

# Catppuccin Mocha palette — raw ESC bytes so printf '%s' works safely.
RESET=$'\033[0m'
GREEN=$'\033[38;2;166;227;161m'   # #a6e3a1
RED=$'\033[38;2;243;139;168m'     # #f38ba8
BLUE=$'\033[38;2;137;180;250m'    # #89b4fa
OVERLAY=$'\033[38;2;108;112;134m' # #6c7086

read_field() {
  grep "^${1}=" "$2" 2>/dev/null | cut -d= -f2-
}

# --- Batch claude detection ---
# One pgrep + one ps call replaces O(n_panes) pgrep invocations.
declare -A CLAUDE_PANE_PIDS
_build_claude_pids() {
  local claude_pids
  claude_pids=$(pgrep -x claude 2>/dev/null) || return 0

  # Build pid -> ppid map from the full process table.
  local -A ppid_map
  while read -r pid ppid; do
    [[ -n "$pid" ]] && ppid_map[$pid]=$ppid
  done < <(ps -eo pid=,ppid= 2>/dev/null)

  local cpid parent grandparent
  for cpid in $claude_pids; do
    parent="${ppid_map[$cpid]:-}"
    [[ -z "$parent" ]] && continue
    # parent is the shell or wrapper; mark it as having claude.
    CLAUDE_PANE_PIDS[$parent]=1
    # grandparent covers shell -> wrapper -> claude.
    grandparent="${ppid_map[$parent]:-}"
    [[ -n "$grandparent" ]] && CLAUDE_PANE_PIDS[$grandparent]=1
  done
}
_build_claude_pids

# Map attention marker to status label + color.
# Sets _status_color and _status_label to avoid subshell forks.
_status_color=""
_status_label=""
get_status() {
  local pane_id="$1"
  local marker="${ATTN_DIR}/${pane_id}"

  if [[ -f "$marker" ]]; then
    local ts ntype
    ts=$(read_field timestamp "$marker")

    # Stale marker — remove and fall through to "Running".
    if [[ -n "$ts" ]] && (( NOW - ts > TTL )); then
      rm -f "$marker"
      _status_color="$GREEN"; _status_label="Running"
      return
    fi

    ntype=$(read_field notification_type "$marker")
    case "$ntype" in
      permission_prompt|elicitation_dialog)
        _status_color="$RED"; _status_label="Waiting for input" ;;
      plan_approval|ask_user_question)
        _status_color="$RED"; _status_label="Asking a question" ;;
      idle_prompt)
        _status_color="$BLUE"; _status_label="Idle" ;;
      *)
        _status_color="$RED"; _status_label="Needs attention" ;;
    esac
  else
    _status_color="$GREEN"; _status_label="Running"
  fi
}

# Fish-style path abbreviation: ~/w/dotfiles for ~/workspace/dotfiles.
abbreviate_path() {
  local path="$1"
  local tilde_path="${path/#$HOME/\~}"
  local IFS='/' parts display=""
  read -ra parts <<< "$tilde_path"
  local n="${#parts[@]}"
  local i p
  for (( i=0; i<n; i++ )); do
    p="${parts[$i]}"
    if (( i == n - 1 )); then
      display+="$p"
    elif [[ -z "$p" ]]; then
      display+="/"
    elif [[ "$p" == ".." ]]; then
      display+="../"
    elif [[ "$p" == .* ]]; then
      display+=".${p:1:1}/"
    else
      display+="${p:0:1}/"
    fi
  done
  printf '%s' "$display"
}

# Switch to a pane (works across tmux sessions).
switch_to_pane() {
  local pane_id="$1"
  local session
  session=$(tmux display-message -t "$pane_id" -p '#{session_name}' 2>/dev/null || true)
  [[ -n "$session" ]] && tmux switch-client -t "$session" 2>/dev/null || true
  tmux select-pane -t "$pane_id" 2>/dev/null || true
}

# --- Pass 1: Identify Claude panes (fast hash lookup, no subprocess per pane) ---
declare -a claude_panes=()
while IFS=$'\t' read -r pane_id session_name win_idx pane_idx pane_pid pane_path; do
  [[ -n "${CLAUDE_PANE_PIDS[$pane_pid]:-}" ]] || continue
  claude_panes+=("${pane_id}	${session_name}	${win_idx}	${pane_idx}	${pane_path}")
  (( ${#claude_panes[@]} >= MAX_SESSIONS )) && break
done < <(tmux list-panes -a -F "#{pane_id}	#{session_name}	#{window_index}	#{pane_index}	#{pane_pid}	#{pane_current_path}")

if [[ ${#claude_panes[@]} -eq 0 ]]; then
  echo "No Claude Code sessions found."
  sleep 1
  exit 0
fi

# --- Pass 2: Gather git info in parallel ---
GIT_TMPDIR=$(mktemp -d)
trap 'rm -rf "$GIT_TMPDIR"' EXIT

for entry in "${claude_panes[@]}"; do
  IFS=$'\t' read -r pane_id _ _ _ pane_path <<< "$entry"
  (
    branch=""
    git_status=$(git -C "$pane_path" status --porcelain -b --short -uno 2>/dev/null || true)
    if [[ -n "$git_status" ]]; then
      IFS=$'\n' read -r header _ <<< "$git_status"
      branch="${header#\#\# }"
      branch="${branch%%...*}"
      branch="${branch%% \[*}"
      if [[ "$branch" == "HEAD (no branch)" ]]; then
        branch=$(git -C "$pane_path" rev-parse --short HEAD 2>/dev/null || true)
      fi
      if [[ "$git_status" == *$'\n'* ]]; then
        branch="${branch}*"
      fi
    fi
    printf '%s\n' "$branch" > "${GIT_TMPDIR}/${pane_id}"
  ) &
done
wait

# --- Pass 3: Assemble display entries ---
entries=()
for entry in "${claude_panes[@]}"; do
  IFS=$'\t' read -r pane_id session_name win_idx pane_idx pane_path <<< "$entry"

  branch=""
  [[ -f "${GIT_TMPDIR}/${pane_id}" ]] && IFS= read -r branch < "${GIT_TMPDIR}/${pane_id}"

  dir=$(abbreviate_path "$pane_path")

  get_status "$pane_id"
  status_color="$_status_color"
  status_label="$_status_label"

  label="${session_name}:${win_idx}.${pane_idx}"

  sep="${OVERLAY} │ ${RESET}"
  line="${status_color}$(printf '%-20s' "$status_label")${RESET}"
  line+="${sep}${BLUE}${dir}${RESET}"
  if [[ -n "$branch" ]]; then
    line+="${sep}${RED}${branch}${RESET}"
  fi
  line+="${sep}${OVERLAY}${label}${RESET}"

  entries+=("$(printf '%s\t%s' "$line" "$pane_id")")
done

if [[ ${#entries[@]} -eq 1 ]]; then
  pane_id=$(printf '%s' "${entries[0]}" | cut -f2)
  switch_to_pane "$pane_id"
  exit 0
fi

selected=$(printf '%s\n' "${entries[@]}" | fzf \
  --ansi \
  --delimiter=$'\t' \
  --with-nth=1 \
  --header="Claude Code Sessions" \
  --reverse \
  --no-sort \
  --preview='tmux capture-pane -t {2} -p -S -20 2>/dev/null || echo "(pane unavailable)"' \
  --preview-window=down:15:wrap) || exit 0

pane_id=$(printf '%s' "$selected" | cut -f2)
switch_to_pane "$pane_id"
