{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-main-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/commit-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-session-start.sh"
          }
        ]
      }
    ]
  }
}
